{
	"name": "@shigen/eslint-plugin",
	"version": "0.15.0",
	"description": "General purpose plugin for ESLint",
	"keywords": [
		"eslint",
		"lint",
		"js",
		"javascript",
		"ts",
		"typescript",
		"es6"
	],
	"license": "ISC",
	"author": "Tao Cumplido",
	"repository": "https://github.com/tao-cumplido/shigen/tree/main/packages/eslint-plugin",
	"bugs": "https://github.com/tao-cumplido/shigen/issues",
	"files": [
		"readme.md",
		"dist/**/*"
	],
	"type": "module",
	"exports": {
		".": "./dist/index.js"
	},
	"scripts": {
		"prepublishOnly": "wireit",
		"test": "wireit",
		"build": "wireit"
	},
	"wireit": {
		"prepublishOnly": {
			"dependencies": [
				"test",
				"build"
			]
		},
		"test": {
			"command": "node --test-reporter spec --test 'src/**/*.test.ts'",
			"files": [
				"src/**/*.ts"
			],
			"output": []
		},
		"build": {
			"command": "tsc --build tsconfig.json",
			"clean": "if-file-deleted",
			"files": [
				"src/**/*.ts",
				"!src/**/*.test.ts",
				"!src/tools/test.ts",
				"../../tsconfig.base.json",
				"tsconfig.json"
			],
			"output": [
				"dist/**",
				"*.tsbuildinfo"
			]
		}
	},
	"engines": {
		"node": "^20.19.0 || ^22.13.0 || >=24"
	},
	"dependencies": {
		"@shigen/enum": "~0.6.0",
		"minimatch": "^10.2.4"
	},
	"devDependencies": {
		"@types/eslint": "9.6.1",
		"@types/estree": "1.0.8",
		"@typescript-eslint/types": "8.57.0",
		"typescript-eslint": "8.57.0",
		"ajv": "8.18.0",
		"eslint": "10.0.3",
		"dedent": "1.7.2"
	},
	"peerDependencies": {
		"typescript-eslint": "^8.56.0",
		"eslint": "^10.0.0"
	},
	"peerDependenciesMeta": {
		"typescript-eslint": {
			"optional": true
		}
	}
}
